# Copy to `.env` and fill in. .env is gitignored.

# Google Sheet ID where leads will be pushed (from the sheet URL).
GSHEET_ID=

# (Optional) Where Camoufox stores its persistent LinkedIn session.
# Default: ~/.ewards-lead-gen/camoufox_profile/
# EWARDS_CAMOUFOX_PROFILE=

# (Optional) Path to a hand-installed Camoufox binary.
# Leave unset to use the bundled browser fetched by `python -m camoufox fetch`.
# EWARDS_CAMOUFOX_EXE=

# (Optional) Override fingerprint OS. Default: auto-detected from your machine.
# Values: windows | macos | linux
# EWARDS_CAMOUFOX_OS=
